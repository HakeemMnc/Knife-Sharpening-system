{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["syd1"],
  "functions": {
    "src/app/api/orders/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/orders/[id]/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/payments/create-intent/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/payments/webhook/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/payments/webhook-test/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/sms/webhook/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/sms/send/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/sms/bulk-send/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/sms/follow-up/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/cron/sms-automation/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sms-automation?type=evening",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sms-automation?type=morning",
      "schedule": "0 21 * * *"
    }
  ]
}